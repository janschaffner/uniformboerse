# Diese Datei ist eine Vorlage – kopiere sie zu .env und fülle die Werte aus.
# .env kommt NIEMALS in Git (ist in .gitignore).
# Auf Netlify trägst du diese Werte unter Site Settings → Environment Variables ein.

# Vereinspasswort (frei wählbar)
VEREIN_PASSWORT=beispiel

# Firebase Admin SDK – Service Account JSON (als einzelne Zeile, Zeilenumbrüche als \n)
FIREBASE_PROJECT_ID=  "beispiel",
FIREBASE_CLIENT_EMAIL=beispiel
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nKey hier\n-----END PRIVATE KEY-----\n"

# Cloudinary
CLOUDINARY_CLOUD_NAME=beispiel
CLOUDINARY_UPLOAD_PRESET=beispiel
